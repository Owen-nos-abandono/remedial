@model ArroyoSecoGastronomia.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Arroyo Seco – Iniciar Sesión</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --gold:#c9a84c;--gold-light:#e2c47a;--dark:#111110;
  --card-bg:#1a1917;--border:#2e2c28;--text:#e8e2d8;
  --muted:#7a746a;--input-bg:#222018;
}
body{font-family:'DM Sans',sans-serif;background:var(--dark);color:var(--text);min-height:100vh;display:flex}

.hero{flex:1;position:relative;overflow:hidden}
.hero-bg{
  position:absolute;inset:0;
  background:url('https://images.unsplash.com/photo-1501854140801-50d01698950b?w=900&q=80') center/cover no-repeat;
  filter:brightness(.5) saturate(.75);
  transition:filter 8s ease;
}
.hero:hover .hero-bg{filter:brightness(.6) saturate(.9)}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(135deg,rgba(0,0,0,.25) 0%,rgba(15,12,4,.72) 100%)}
.hero-content{position:relative;z-index:2;height:100%;display:flex;flex-direction:column;justify-content:center;align-items:flex-start;padding:3.5rem 4rem}
.logo{width:68px;margin-bottom:2.5rem;filter:drop-shadow(0 2px 12px rgba(201,168,76,.4))}
.hero-title{font-family:'Playfair Display',serif;font-size:clamp(2.6rem,4vw,4rem);color:#fff;line-height:1.05;margin-bottom:.65rem;text-shadow:0 2px 20px rgba(0,0,0,.5)}
.hero-subtitle{font-style:italic;color:var(--gold-light);font-size:1.05rem;margin-bottom:3rem;opacity:.92}
.features{display:flex;flex-direction:column;gap:.8rem}
.feat{display:flex;align-items:center;gap:.9rem;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.09);border-radius:11px;padding:.65rem 1.25rem;backdrop-filter:blur(8px);font-size:.93rem;width:fit-content;min-width:230px;transition:background .2s,border-color .2s}
.feat:hover{background:rgba(201,168,76,.1);border-color:rgba(201,168,76,.3)}
.feat-icon{font-size:.85rem;color:var(--gold);width:20px;text-align:center}

.auth-panel{width:490px;flex-shrink:0;background:#141310;display:flex;flex-direction:column;justify-content:center;padding:3rem 2.8rem;position:relative}
.back-link{position:absolute;top:2rem;left:2.8rem;display:flex;align-items:center;gap:.45rem;color:var(--muted);text-decoration:none;font-size:.88rem;transition:color .2s}
.back-link:hover{color:var(--text)}
.back-link svg{width:14px;height:14px}
.auth-card{background:var(--card-bg);border:1px solid var(--border);border-radius:18px;padding:2.5rem 2.2rem}
.auth-card h1{font-family:'Playfair Display',serif;font-size:1.8rem;color:#fff;text-align:center;margin-bottom:.4rem}
.tagline{text-align:center;color:var(--muted);font-size:.88rem;margin-bottom:2rem}
.field-label{display:block;font-size:.7rem;font-weight:500;letter-spacing:.12em;color:var(--muted);text-transform:uppercase;margin-bottom:.5rem}
.input-wrap{position:relative;margin-bottom:1.15rem}
.input-wrap svg.prefix{position:absolute;left:.9rem;top:50%;transform:translateY(-50%);color:var(--muted);width:15px;height:15px;pointer-events:none}
.input-wrap input{
  width:100%;background:var(--input-bg);border:1px solid var(--border);border-radius:10px;
  padding:.82rem 1rem .82rem 2.6rem;color:var(--text);font-size:.93rem;font-family:'DM Sans',sans-serif;outline:none;transition:border-color .2s,box-shadow .2s
}
.input-wrap input:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(201,168,76,.12)}
.input-wrap input::placeholder{color:var(--muted)}
.eye-btn{position:absolute;right:.9rem;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--muted);cursor:pointer;padding:0;display:flex;transition:color .2s}
.eye-btn:hover{color:var(--text)}
.row-opts{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem}
.chk-label{display:flex;align-items:center;gap:.5rem;font-size:.87rem;cursor:pointer}
.chk-label input{accent-color:var(--gold);width:14px;height:14px}
.forgot{font-size:.87rem;color:var(--gold);text-decoration:none}
.forgot:hover{color:var(--gold-light)}
.btn-login{width:100%;background:var(--gold);color:#1a1507;border:none;border-radius:10px;padding:.9rem;font-size:.82rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;cursor:pointer;font-family:'DM Sans',sans-serif;transition:background .2s,transform .1s,box-shadow .2s}
.btn-login:hover{background:var(--gold-light);box-shadow:0 4px 20px rgba(201,168,76,.3)}
.btn-login:active{transform:scale(.99)}
.divider{display:flex;align-items:center;gap:.75rem;margin:1.5rem 0;color:var(--muted);font-size:.78rem}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--border)}
.footer-links{text-align:center;font-size:.86rem;color:var(--muted);line-height:2.1}
.footer-links a{color:var(--gold);font-weight:600;text-decoration:none}
.footer-links a:hover{color:var(--gold-light)}
.validation-summary{background:rgba(200,60,60,.1);border:1px solid rgba(200,60,60,.3);color:#e07878;border-radius:9px;padding:.65rem .9rem;font-size:.87rem;text-align:center;margin-bottom:1.2rem}
.validation-summary ul{list-style:none;padding:0;margin:0}
@@media(max-width:768px){
  .hero{display:none}
  .auth-panel{width:100%;padding:2rem 1.4rem}
}
</style>
</head>
<body>

<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <svg class="logo" viewBox="0 0 72 72" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="lg" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#e2c47a"/>
          <stop offset="100%" stop-color="#c9a84c"/>
        </linearGradient>
      </defs>
      <polygon points="36,5 67,63 5,63" fill="url(#lg)" opacity=".95"/>
      <text x="36" y="52" text-anchor="middle" font-size="13" fill="#ececec" font-weight="bold" font-family="sans-serif">AS</text>
    </svg>
    <h1 class="hero-title">Arroyo Seco</h1>
    <p class="hero-subtitle">"El tesoro escondido de Querétaro"</p>
    <div class="features">
      <div class="feat"><span class="feat-icon">▦</span> Unicamente Gastronomía</div>
      <div class="feat"><span class="feat-icon">⑁</span> Gastronomía Queretana</div>
      <div class="feat"><span class="feat-icon">▲</span> Experiencia Turistica de Turismo</div>
    </div>
  </div>
</section>

<section class="auth-panel">
  <a href="#" class="back-link">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M5 12l7-7M5 12l7 7"/></svg>
    Regresar al inicio
  </a>

  <div class="auth-card">
    <h1>Bienvenido de vuelta</h1>
    <p class="tagline">Inicia sesión para continuar tu experiencia</p>

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="validation-summary"></div>
    }

    <form asp-action="Login" asp-controller="Account" method="post">
      @Html.AntiForgeryToken()

      <label class="field-label">Correo Electrónico</label>
      <div class="input-wrap">
        <svg class="prefix" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        <input asp-for="Email" type="email" placeholder="tu@correo.com" value="oferente@gastronomia.com"/>
      </div>

      <label class="field-label">Contraseña</label>
      <div class="input-wrap">
        <svg class="prefix" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        <input asp-for="Password" type="password" id="passInput" placeholder="••••••••"/>
        <button type="button" class="eye-btn" onclick="togglePass()">
          <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
        </button>
      </div>

      <div class="row-opts">
        <label class="chk-label">
          <input asp-for="RememberMe" type="checkbox"/> Recordarme
        </label>
        <a href="#" class="forgot">¿Olvidaste tu contraseña?</a>
      </div>

      <button type="submit" class="btn-login">Iniciar Sesión</button>
    </form>

    <div class="divider">o</div>
    <div class="footer-links">
      ¿No tienes cuenta? <a href="#">Regístrate aquí</a><br>
      Credenciales de prueba: <span style="color:#c9a84c">oferente@gastronomia.com / password123</span>
    </div>
  </div>
</section>

<script>
function togglePass() {
  const inp = document.getElementById('passInput');
  inp.type = inp.type === 'password' ? 'text' : 'password';
}
</script>
</body>
</html>
